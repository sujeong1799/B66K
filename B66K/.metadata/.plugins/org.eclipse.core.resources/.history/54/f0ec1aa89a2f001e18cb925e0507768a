@charset "UTF-8";

* {
  box-sizing: border-box;
}

*::after::before {
  box-sizing: border-box;
}

body {
  margin: 0;
  padding: 0;
}


.listContent{
	    width: 100%;
	    height: 850px;
	    margin-top: 50px;
}

.listBox{
	width:800px;
	margin: 0px 600px;
}

.listBox > p{
	font-size: 30px;
}
.listAddBtn {
    color: #fff;
    width: 90px;
    height: 45px;
    background-color: #212529;
    border: 1px solid #212529;
    border-radius: 4px;
}

.listAddBtn:hover {
    background-color: #212529;
    color: white;
    border: 1px solid #212529;
    transition: all 0.3s ease-out;
    border-radius: 4px;
}

.listMainBtn {
    color: #fff;
    width: 90px;
    height: 45px;
    background-color: #212529;
    /* border: 1px solid #212529; */
    border: none;
    border-radius: 4px;
}

.listMainBtn:hover {
    background-color: #212529;
    color: white;
    border: 1px solid #212529;
    transition: all 0.3s ease-out;
    border-radius: 4px;
}