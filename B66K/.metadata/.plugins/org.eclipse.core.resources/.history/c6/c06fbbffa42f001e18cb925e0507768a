@charset "UTF-8";

* {
	box-sizing: border-box;
}

*::after::before {
	box-sizing: border-box;
}

body {
	margin: 0;
	padding: 0;
}

.ModifyContent {
	width: 100%;
	height: 850px;
	margin-top: 50px;
}

.ModifyBox {
	width: 800px;
	margin: 0px 600px;
}

.ModifyBox>p {
	font-size: 30px;
}

.ck-content { /* ckeditor 높이 */
	height: 170px;
}

