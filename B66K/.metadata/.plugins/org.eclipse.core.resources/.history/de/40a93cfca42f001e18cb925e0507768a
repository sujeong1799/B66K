@charset "UTF-8";

* {
  box-sizing: border-box;
}

*::after::before {
  box-sizing: border-box;
}

body {
  margin: 0;
  padding: 0;
}


.detailContent {
	    width: 100%;
	    height: 850px;
	    margin-top: 50px;
}

.detailBox {
	width: 800px;
	margin: 0px 600px;
}

.detailTable {
	width: 800px;
}

.detailBox > p{
	font-size: 30px;
}

.contentPage{
	resize: none;
}

.imgList > img{
	width: 100px;
	height: 150px;
}

