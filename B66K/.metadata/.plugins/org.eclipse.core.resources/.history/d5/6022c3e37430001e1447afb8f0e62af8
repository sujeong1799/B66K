@media screen and (min-width:1600px)
@charset "UTF-8";

@font-face {
    font-family: 'IBMPlexSansKR-Regular';
    src: url('https://cdn.jsdelivr.net/gh/projectnoonnu/noonfonts_20-07@1.0/IBMPlexSansKR-Regular.woff') format('woff');
    font-weight: normal;
    font-style: normal;
}
*{
 font-family: 'IBMPlexSansKR-Regular';
}


.navbar{
 background-color: #212529;
  /*  background-color: white; */
   box-shadow: rgba(0, 0, 0, 0.1) 0px 4px 6px -1px, rgba(0, 0, 0, 0.06) 0px 2px 4px -1px;
}

.navbar-brand > img{
   width: 70px;
   height: auto;
   
}

.headerBtn{
   background: #212529;
   color: white;
}

.headerBtn > span{
   color: white;
}

.navbar-brand {
   color: white;
   text-decoration: none;
}


.navbar-brand:hover {
   color: white;
}

.navlog {
   text-decoration: none;
   margin-right: 20px;
   color: white;
}

.navlog:hover {
   color: white;
}



.btn-secondary {
   background-color: black;
   border: none;
}

.btn-secondary:hover {
   background-color: black;
}

ul, li {
   list-style: none;
}

a:hover{
   color: black;
}

/* 사이드바 */

.SideBar a {
   text-decoration: none;
   color: black
}

.SideBar a:hover {
   color: black;
}

.SideBar {
   width: 300px;
   height: 900px;
   float: left;
   border-right: 1px solid #bcbcbc;
   background-color: #F2F2F2;
}

.SideBarMain{
   width: 300px;
   margin: 0px 0px;
   background-color: #FF9436;
}

.SideBarMain > p{
   width: 200px;
   font-size: 30px;
   margin: 0px auto;
   color: white;
   
}

.SideBar .dep1>li {
   width: 100px;
}

.SideBar .dep2>li {
   width: 100px;
}

.dep2{
   margin: 0px 0px;
   padding: 0px 20px;
}

.dep1{
   margin-left: 50px;
}

.dep1 > li > div{
   width: 150px;
   height: 30px;
}

.dep1 > li > div > span{
   font-size: 20px;
}

.userNickname{
   color: white;
   
}

.imgIcon{
   width: 40px;
   height: 40px;
   border-radius: 50%;
}


.userDropdown{
   margin-left: 140px;
   position: fixed;
}

.userNickname{
   margin-right: 20px;
}




/* footer */

.footerMainDiv{
	border:1px dotted #bcbcbc;
	width: 100%;
	height: 200px;
	background-color: white;
}

.footerContent{
	font-size: 14px;
	width: 100%;
	height: 150px;
	background-color: white;
}