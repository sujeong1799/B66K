.paybtn {
   
   padding-top:32px;
   width: 200px;
   height: 100px;
   font-size:30px;

   text-align:center;
    display: inline-block; 
    
   margin: 0; 
    border: 0 none;
    outline: none;
    text-decoration: none;
    
    cursor: pointer;
    -webkit-mask-image: -webkit-radial-gradient(#fff,#000);
    line-height: 1;
    position: relative;
    background-color: #212529;
    border-radius: 4px;
    transition: color .3s cubic-bezier(.25,.46,.45,.94);
    overflow: hidden;
    color: #ffffff;
    text-align: center;
    &:hover {
      color: #fff;
      .button-overlay:after {
        transform: scale(2.5);
      }
    }
    &:before {
      position: absolute;
      top: 100%;
      left: 0;
      content: "";
      background-color: #fff;
      border-radius: 50%;
    }
}

.button-overlay {
    position: relative;
    height: auto;
    width: 100%;
    position: absolute;
    top: 100%;
    right: 100%;
  
    &:before {
      padding-top: 100%;
      display: block;
      content: "";
    }
    &:after {
      position: absolute;
      bottom: 0;
      left: 0;
      height: 100%;
      width: 100%;
      content: "";
      transition: transform .5s cubic-bezier(.25,.46,.45,.94);
      background-color: #faa307;
      border-radius: 50%;
      transform: scale(1);
      transform-origin: bottom left;
    }
}

.button-text {
  color:#fff;
  position: relative;

}
 





