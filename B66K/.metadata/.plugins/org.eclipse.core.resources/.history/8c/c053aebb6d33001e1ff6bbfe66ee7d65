@charset "UTF-8";

* {
	box-sizing: border-box;
}

*::after::before {
	box-sizing: border-box;
}

body {
	margin: 0;
	padding: 0;
}

.orderDetailContent {
	width: 100%;
	height: 100%;
	margin-top: 50px;
}

.orderDetailBox {
	width: 800px;
	height: 100%;
	margin: 0px 600px;
}

.orderDetailBox>p {
	font-size: 30px;
	color: #212529;
	font-weight: bold;
}

.orderDetailImg {
	width: 70xp;
	height: 100px;
}


.btnBox{
	height: 100px;
	
}
.orderDetailTable {
	width: 800px;
}

.orderDetailcancelBtn{
	    color: #fff;
    width: 90px;
    height: 45px;
    background-color: #212529;
    /* border: 1px solid #212529; */
    border: none;
    border-radius: 4px;
}

.orderDetailmodifyBtn{
    color: #fff;
    width: 100px;
    height: 45px;
    background-color: #212529;
    /* border: 1px solid #212529; */
    border: none;
    border-radius: 4px;
}

.pagination>li, ul { -
	-bs-pagination-focus-box-shadow: 0 0 0 0.01rem #faa307; -
	-bs-pagination-color: #212529; -
	-bs-pagination-border-color: #212529; -
	-bs-pagination-hover-color: #fff; -
	-bs-pagination-focus-color: #fff; -
	-bs-pagination-active-border-color: #212529; -
	-bs-pagination-hover-border-color: #212529; -
	-bs-pagination-hover-bg: #212529; -
	-bs-pagination-focus-bg: #212529; -
	-bs-pagination-active-color: #fff; -
	-bs-pagination-active-bg: #fff; -
	-bs-pagination-disabled-color: #212529; -
	-bs-pagination-disabled-border-color: #212529; -
	-bs-pagination-disabled-bg: #fff; -
	-bs-pagination-border-radius: 4px;
}