@media screen and (min-width:1600px)
@charset "UTF-8";
@font-face {
    font-family: 'IBMPlexSansKR-Regular';
    src: url('https://cdn.jsdelivr.net/gh/projectnoonnu/noonfonts_20-07@1.0/IBMPlexSansKR-Regular.woff') format('woff');
    font-weight: normal;
    font-style: normal;
}
*{
 font-family: 'IBMPlexSansKR-Regular';
}


body{-ms-overflow-style:none; }
body::-webkit-scrollbar { display:none; }

.navbar{
   width: 100%;
   background-color: #212529;
   box-shadow: rgba(0, 0, 0, 0.1) 0px 4px 6px -1px, rgba(0, 0, 0, 0.06) 0px 2px 4px -1px;
}

a:hover{
   color: black;
}

.userNickname{
   color: white;
}

.headerLine{
   position : absolute;
   border-right: 1px solid #BCBCBC;
   height: 30px; 
   width: 1px;
   left: 120px;
}

.imgIcon{
   width: 40px;
   height: 40px;
   border-radius: 50%;
   margin-right: 20px;
}

.headerBtn{
   background: #212529;
   color: white;
}

.headerBtn > span{
   color: white;
}

.navbar-brand {
   color: white;
   text-decoration: none;
}


.navbar-brand:hover {
   color: white;
}

.navbar-brand > img{
   width: 70px;
   
}

.navlog {
   text-decoration: none;
   margin-right: 20px;
   color: white;
}

.navlog:hover {
   color: white;
}

.navlog > a:hover {
   color: white;
}

.btn-secondary {
   background-color: black;
   border: none;
}

.btn-secondary:hover {
   background-color: black;
}

ul, li {
   list-style: none;
}

/* 이거추가함. */
.form-control:focus{
  box-shadow: none;
  border: 1px solid black;
} 

.userDropdown{
   margin-left: 120px;
}

.dropdown{
   float: left;
}
.headerSearchIcon{
   width: 30px;
   height: 30px;
   z-index: 30;
   color: white;
   cursor: pointer;
   /* background-color: red; */
   position: absolute;
   left: 140px;
   
}
.headerSearchDiv{
   position : absolute;
   width: 200px;
   height: 30px;
   /* background-color: red; */
   display: none;
   float: left;
   left: 180px;
}

.headerSearch{
   width: 200px;
   height: 30px;
   padding-left: 10px;
   padding-right : 20px;
   font-size: 14px;
   color : white;
   border-left-width: 0;
   border-right-width: 0;
   border-top-width: 0;
   border-bottom-width: thin;
   background-color: #212529;
   z-index: 20;
   
}

.headerSearch:focus{
   outline: none;
}


.headerSearch:-webkit-autofill {
   -webkit-box-shadow: 0 0 0 1000px #212529 inset;
   box-shadow: 0 0 0 1000px #212529 inset;
   color: white;
}

.headerListSearchBtn{
   width : 50px;
   height : 30px;
   position : absolute;
   background-color: #212529;
   border : none;
   color: white;
   left: 180px;
}

/* 사이드바 */

.SideBar a {
   text-decoration: none;
   color: white
}

.SideBar a:hover {
   color: white;
}

.SideBar {
   width: 300px;
   /* height: 910px; */
   float: left;
   border-right: 1px solid #bcbcbc;
   background-color: #212529;
}

.SideBarMain{
   width: 290px;
   margin: 30px 0px 0px 0px;
   background-color: #212529;
}

.SideBarMain > p{
   width: 200px;
   font-size: 30px;
   margin: 0px auto;
   color: white;
   font-weight: bold;
   
}

.SideBar .dep1>li {
   width: 100px;
}

.SideBar .dep2>li {
   width: 100px;
}

.dep2{
   margin: 0px 0px;
   padding: 0px 20px;
}

.dep2 > li:hover{
   font-weight: bold;
}

.dep1{
   margin-left: 50px;

}

.dep1 > li > div{
   width: 150px;
   height: 40px;
   
}

.dep1 > li > div > span{
   font-size: 20px;
   color: #faa307;
   font-weight: bold;
}


/* footer */

.footerMainDiv{
  /*  border-top:1px solid #212529; */
   border-top:1px solid white;
   box-shadow: rgba(17, 17, 26, 0.1) 0px 0px 16px;

   width: 100%;
   height: 200px;
   /* background-color: #212529; */
   background-color: white;
   position: relative;
   
   
}

.footerContent{
   font-size: 14px;
   width: 500px;
   height: 200px;
   background-color: white;
   color : black;
   margin-left: 100px;
   float: left;
}

.footerContent p:first-child {
   margin-top: 35px;
}


.footerSideDiv{
   width: 600px;
   height: 100px;
   /* background-color: red; */
   float: left;
   
   position: absolute;
   right: 10px;
   
   top: 90px;
}



.footerSideDiv a{
   /* color: white; */
   color : black;
   text-decoration: none;
   margin-right: 25px;
   font-size: 20px;
}

.footerSideDiv a:first-child{
   margin-left: 40px;
}

.footerLogoDiv{
   width: 120px;
   height: 100px;
   /* background-color: yellow; */
   float: left;
   position: absolute;
   left: 900px;
   top: 75px;
}

.footerLogo{
   width: 90px;
   height: auto;
   position: absolute;
}

